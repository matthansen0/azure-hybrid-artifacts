            "actionGroupId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the Action Group to trigger."
              }
            },
            "targetSubscriptionId": {
              "type": "string",
              "defaultValue": "[subscription().subscriptionId]",
              "metadata": {
