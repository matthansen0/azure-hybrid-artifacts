          "resources": [
            {
              "type": "Microsoft.Insights/activityLogAlerts",
              "apiVersion": "2020-10-01",
              "name": "[variables('alertRuleName')]",
              "location": "Global",
              "tags": "[parameters('tags')]",
              "properties": {
                "description": "Fires when an Azure Arc-enabled machine comes back online (Resource Health: Unavailable → Available). Triggers catch-up patching via Azure Function.",
                "enabled": true,
                "scopes": [
                  "[format('/subscriptions/{0}', parameters('targetSubscriptionId'))]"
                ],
                "condition": {
                  "allOf": [
                    {
                      "field": "category",
                      "equals": "ResourceHealth"
                    },
                    {
                      "field": "resourceType",
                      "equals": "Microsoft.HybridCompute/machines"
                    },
                    {
                      "field": "properties.currentHealthStatus",
                      "equals": "Available"
                    },
                    {
                      "field": "properties.previousHealthStatus",
                      "equals": "Unavailable"
                    }
                  ]
                },
                "actions": {
                  "actionGroups": [
                    {
                      "actionGroupId": "[parameters('actionGroupId')]"
                    }
                  ]
                }
              }
            }
          ],
          "outputs": {
